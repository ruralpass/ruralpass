# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RESEND_API_KEY: Requerido para envío de emails desde el formulario de contacto.
# Obtener en https://resend.com → API Keys
RESEND_API_KEY="re_QkkpXTGi_EsE2xxp9R2oSsPsUkvd5JkCa"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_CLARITY_PROJECT_ID: ID del proyecto de Microsoft Clarity para analítica de comportamiento.
# Obtener en https://clarity.microsoft.com/ → Settings → Setup (Project ID).
# IMPORTANTE: debe empezar con NEXT_PUBLIC_ para que Next.js lo exponga al cliente.
NEXT_PUBLIC_CLARITY_PROJECT_ID="MY_CLARITY_PROJECT_ID"
